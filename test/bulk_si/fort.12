%YAML 1.2
---

siesta:
  version: "4.1.5"
  arch: "arm64"
  compiler: "GNU Fortran (Homebrew GCC 12.2.0) 12.2.0"
  fflags: "mpif90 -O2 -fPIC -ftree-vectorize -fallow-argument-mismatch"
  fppflags: "-DCDF -DNCDF -DNCDF_4 -DMPI -DFC_HAVE_ABORT"
  libs: "libncdf.a libfdict.a -L/opt/homebrew/lib -lnetcdff -lnetcdf -lhdf5_hl -lhdf5  -lz -lscalapack -L/opt/homebrew/opt/openblas/lib -lopenblas"
  build: "mpi"
  openmp: "no"
  gemm3m: "no"
  netcdf: "yes"
  netcdf4: "yes"
  netcdf4_mpi: "no"
  metis: "no"
  chess: "no"
  elpa: "no"
  flook: "no"
  pexsi: "no"

energies:
  Ebs:          -0.63402619E+01
  Eions:           0.27753638E+02
  Ena:           0.85233179E+01
  Ekin:           0.59954755E+01
  Enl:           0.20428289E+01
  Eso:           0.00000000E+00
  Edftu:           0.00000000E+00
  DEna:           0.90655282E-01
  DUscf:           0.28198925E-01
  DUext:           0.00000000E+00
  Exc:          -0.47726513E+01
  Ecorrec:           0.00000000E+00
  Emadel:           0.00000000E+00
  Emeta:           0.00000000E+00
  Emolmec:           0.00000000E+00
  Ekinion:           0.00000000E+00
